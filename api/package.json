{
  "name": "myhonda-sfs-api",
  "main": "index.js",
  "version": "1.0.0",
  "description": "MyHonda SFS API",
  "author": "Felipe Torres <ftmacedo.torres@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "NODE_ENV=production node build/index.js",
    "start:dev": "NODE_ENV=development nodemon --delay 500ms --inspect --exec babel-node index.js",
    "dev": "set NODE_ENV=development && nodemon --delay 500ms --inspect --exec babel-node index.js",
    "db:migrate": "npx -y sequelize-cli db:migrate",
    "db:migrate:status": "npx -y sequelize-cli db:migrate:status",
    "db:migrate:undo": "npx -y sequelize-cli db:migrate:undo",
    "db:seed": "npx -y sequelize-cli db:seed:all",
    "lint": "eslint --ext .js ./src ./migrations",
    "lint:fix": "npm run lint --fix",
    "build": "npm run build:api",
    "build:api": "babel ./index.js --out-dir ./build && babel ./src --out-dir ./build/src"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@casl/ability": "^6.7.2",
    "aws-sdk": "^2.1599.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.0.0",
    "express": "^4.17.2",
    "handlebars": "^4.7.8",
    "helmet": "^5.0.2",
    "http-status": "^2.0.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.5",
    "nodemailer": "^6.10.0",
    "prisma": "^5.22.0",
    "sanitize-html": "^2.7.0",
    "sequelize": "^6.37.5",
    "swagger-ui-express": "^5.0.1",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.0",
    "@babel/core": "^7.17.2",
    "@babel/node": "^7.16.8",
    "@babel/preset-env": "^7.16.11",
    "@babel/register": "^7.17.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "copy": "^0.3.2",
    "eslint": "^8.8.0",
    "nodemon": "^3.1.14",
    "semver": "^7.3.5"
  },
  "resolutions": {
    "graceful-fs": "4.x.x"
  }
}
