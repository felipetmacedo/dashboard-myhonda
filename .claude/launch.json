{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 8080,
      "autoPort": true
    },
    {
      "name": "front",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "front"],
      "port": 8080,
      "autoPort": true
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "api", "run", "dev"],
      "port": 3000
    }
  ]
}
